# AI 配置 - 留空表示使用模拟返回
# 推荐：在网页端的「设置」面板中填写（更安全，避免泄露到代码仓库）

# OpenAI 官方
# AI_API_KEY=sk-your-openai-key
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-3.5-turbo

# DeepSeek
# AI_API_KEY=sk-your-deepseek-key
# AI_API_BASE=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# 智谱AI
# AI_API_KEY=your-zhipu-key
# AI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
# AI_MODEL=glm-4-flash

# 留空时，将使用模拟返回
AI_API_KEY=
AI_API_BASE=
AI_MODEL=

# 是否使用模拟返回（未配置 API Key 时自动为 true）
USE_MOCK=true

# 联网搜索 API Key（用于简历「联网参考同类简历」功能，可选）
# 默认对接 Tavily（https://tavily.com，有免费额度）；留空则该功能回退为基础优化。
SEARCH_API_KEY=
# 可选：自定义搜索端点 / 供应商（默认 Tavily）
# SEARCH_API_BASE=https://api.tavily.com/search
